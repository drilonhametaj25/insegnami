# InsegnaMi.pro Production Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://insegnami:YOUR_SECURE_PASSWORD@localhost:5432/insegnami?schema=public
POSTGRES_DB=insegnami
POSTGRES_USER=insegnami
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://insegnami.pro

# ===========================================
# STRIPE (Payments)
# ===========================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@insegnami.pro

# ===========================================
# REDIS (Optional - for caching)
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=production
MODE=saas
